# ============================================================
# MediDesk Backend Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres_secure_password_2026@localhost:5432/medidesk"

# JWT
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars-long"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS S3 (leave blank to use local mock storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=medidesk-uploads

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200

# AI / LLM (optional - uses rule engine if blank)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Email / Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@medidesk.com

# Frontend Origin (CORS)
FRONTEND_URL=http://localhost:3000
